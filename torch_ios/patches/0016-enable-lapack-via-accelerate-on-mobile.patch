# torch_ios: enable LAPACK via Apple's Accelerate.framework on iOS.
#
# Symptom (without patch): after import-torch succeeds, calls to
# torch.linalg.lu_factor / det / inv / svd / cholesky / qr fail with
#   "Calling torch.linalg.lu_factor on a CPU tensor requires compiling
#    PyTorch with LAPACK. Please use PyTorch built with LAPACK support."
#
# Root cause: cmake/Dependencies.cmake gates the LAPACK detection block
# (find_package(LAPACK), set USE_LAPACK 1, etc.) behind
# `if(NOT INTERN_BUILD_MOBILE)` — assuming mobile builds don't have a
# LAPACK provider. But on iOS we DO have one: Apple's Accelerate.framework
# bundles LAPACK alongside BLAS in vecLib (the cheev_/dgesvd_/dgetrf_/etc.
# symbols are right there).
#
# Patch: honor a caller-set `-DUSE_LAPACK=1` even under INTERN_BUILD_MOBILE.
# build_libtorch.sh now passes:
#   -DUSE_LAPACK=1
#   -DLAPACK_LIBRARIES="-framework Accelerate"
#   -DCAFFE2_USE_ACCELERATE=ON

diff --git a/cmake/Dependencies.cmake b/cmake/Dependencies.cmake
--- a/cmake/Dependencies.cmake
+++ b/cmake/Dependencies.cmake
@@ -1618,6 +1618,21 @@
 # --[ ATen checks
 set(USE_LAPACK 0)

+# torch_ios: under INTERN_BUILD_MOBILE the entire LAPACK detection block
+# below (around line 1730) is skipped, so USE_LAPACK stays at 0. But on
+# iOS we DO have LAPACK via Apple's Accelerate.framework — caller may
+# pass -DUSE_LAPACK=1 -DLAPACK_LIBRARIES=... to opt in. Honor it here so
+# the rest of the build picks it up (linalg/inv/svd/lu_factor work).
+if(INTERN_BUILD_MOBILE AND DEFINED CACHE{USE_LAPACK} AND $CACHE{USE_LAPACK})
+    set(USE_LAPACK 1)
+    if(NOT DEFINED LAPACK_LIBRARIES)
+        set(LAPACK_LIBRARIES "-framework Accelerate")
+    endif()
+    list(APPEND Caffe2_PRIVATE_DEPENDENCY_LIBS ${LAPACK_LIBRARIES})
+    message(STATUS "torch_ios: USE_LAPACK forced ON, libs=${LAPACK_LIBRARIES}")
+endif()
+
 # we need to build all targets to be linked with PIC
