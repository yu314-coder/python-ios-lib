# llama.xcframework debug symbols (dSYM is for Xcode crash symbolication;
# not needed by end users, ~300 MB across 4 platforms)
Frameworks/llama.xcframework/**/dSYMs/

# __pycache__/ gets regenerated at runtime with runtime-correct paths
__pycache__/

# numpy cross-compile build scratch (we ship the finished .so files
# in app_packages; users rebuild from source via numpy_ios/build_numpy_ios.sh)
numpy_ios/build/
numpy_ios/install/
numpy_ios/numpy-*.tar.gz
numpy_ios/numpy-2.*/

# Pillow iOS cross-compile scratch (keep only build script + shipped .so)
pillow_ios/build_libjpeg/
pillow_ios/install/
pillow_ios/libjpeg-turbo-*/
pillow_ios/libjpeg-turbo*.tar.gz
pillow_ios/pillow-*.tar.gz
pillow_ios/pillow-*/

# pandas cross-compile scratch (attempted but pandas 2.0 is not Python 3.14 compatible;
# keep build script as reference for future attempts)
pandas_ios/pandas-*/
pandas_ios/pandas-*.tar.gz

# psutil cross-compile scratch (keep build script + shim_include, skip source tree)
psutil_ios/psutil-*/
psutil_ios/psutil-*.tar.gz

# Torch dylib (>100MB, exceeds GitHub's per-file limit; LFS is
