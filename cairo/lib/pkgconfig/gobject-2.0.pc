prefix=/tmp/cairo-ios/install
includedir=${prefix}/include
libdir=${prefix}/lib

Name: GObject
Description: GLib Type, Object, Parameter and Signal Library
Version: 2.74.0
Requires: libffi, glib-2.0
Libs: -L${libdir} -lgobject-2.0 -lintl
Cflags: -I${includedir} -DFFI_STATIC_BUILD -DG_INTL_STATIC_COMPILATION
