# torch_ios: provide stub definitions for the 6 torch::jit ONNX export
# functions whose real implementations live in files we exclude under
# INTERN_DISABLE_ONNX (they need onnx_pb.h):
#
#   export_onnx, serialize_model_proto_to_string, pretty_print_onnx
#     → torch/csrc/jit/serialization/export.cpp
#   addNodeToBlock, addInputToBlock
#     → torch/csrc/jit/passes/onnx/helper.cpp
#   _save_parameters  (2 overloads)
#     → torch/csrc/jit/mobile/train/export_data.cpp
#
# Also stubs torch::lazy::InitTorchScriptBackend (BUILD_LAZY_TS_BACKEND=OFF).
#
# pybind11 `m.def("export_onnx", &export_onnx)` in torch_python grabs these
# function pointers at MODULE-INIT time (not at call time), so if the
# symbols are missing dlopen fails. Stubs throw at runtime so users who
# actually call torch.onnx.export on iPad get a clear "use ExecuTorch"
# error; `import torch` succeeds.
#
# The stub source lives in pytorch/torch_ios_stubs/torch_ios_onnx_stubs.cpp
# and is included via torch/CMakeLists.txt.

diff --git a/torch/CMakeLists.txt b/torch/CMakeLists.txt
--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -73,6 +73,18 @@
         PROPERTIES COMPILE_DEFINITIONS TORCH_IOS_DEFINE_LAZY_FLAGS)
 endif()

+# torch_ios: under full mode + INTERN_DISABLE_ONNX, ~6 ONNX-related functions
+# (export_onnx, pretty_print_onnx, serialize_model_proto_to_string,
+# addNodeToBlock, addInputToBlock, _save_parameters) stay undefined because
+# export.cpp / onnx.cpp / passes/onnx/helper.cpp / mobile/train/export_data.cpp
+# need onnx_pb.h which we don't generate. pybind11 m.def() in torch_python
+# takes function pointers at module-init time though, so we must provide
+# at least stub definitions or dlopen fails.
+if(INTERN_BUILD_MOBILE AND NOT BUILD_LITE_INTERPRETER AND INTERN_DISABLE_ONNX)
+    list(APPEND TORCH_PYTHON_SRCS
+        "${TORCH_ROOT}/torch_ios_stubs/torch_ios_onnx_stubs.cpp")
+endif()
+
 # NB: This has to match the condition under which the JIT test directory
 #     is included (at the time of writing that's in caffe2/CMakeLists.txt).
 if(BUILD_TEST)
