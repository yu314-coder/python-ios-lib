# Environment
.env
.venv/

# torch_ios build artifacts (1.7 GB of CMake + object files + huge static libs)
torch_ios/build/

# tokenizers_ios cloned upstream + Rust target dir (250 MB; users clone fresh)
tokenizers_ios/tokenizers/

# torch_ios build scratch — intermediate .o / .a files (not needed at runtime)
app_packages/site-packages/torch/lib/*.a

# Runtime binaries ARE shipped so `import torch` works immediately after
# cloning. libtorch_python.dylib is 99 MB — uses Git LFS (see .gitattributes).
# Users building from source locally can overwrite via torch_ios/scripts/install_to_app.sh.

# .venv_hf/ used by install_to_app.sh as source for HF deps
torch_ios/.venv_hf/
.venv_hf/
