prefix=/tmp/cairo-ios/install
includedir=${prefix}/include
libdir=${prefix}/lib

bindir=${prefix}/bin
glib_genmarshal=${bindir}/glib-genmarshal
gobject_query=${bindir}/gobject-query
glib_mkenums=${bindir}/glib-mkenums

Name: GLib
Description: C Utility Library
Version: 2.74.0
Requires: libpcre2-8
Libs: -L${libdir} -lglib-2.0 -lintl -liconv -lm
Cflags: -I${includedir}/glib-2.0 -DPCRE2_STATIC -DG_INTL_STATIC_COMPILATION -I${libdir}/glib-2.0/include
