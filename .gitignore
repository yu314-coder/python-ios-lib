# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
*.whl

# Exceptions: a few bundled deps ship as sourceless bytecode (no .py),
# so the blanket `*.pyc` above would drop them from the repo entirely —
# breaking fresh clones / SwiftPM consumers (matplotlib & pandas hard-
# import these). Keep their top-level .pyc tracked (NOT __pycache__,
# which is regenerated at runtime). See Sources/Dateutil in Package.swift.
!app_packages/site-packages/six.pyc
!app_packages/site-packages/dateutil/*.pyc
!app_packages/site-packages/dateutil/parser/*.pyc
!app_packages/site-packages/dateutil/tz/*.pyc
# Same deal for the Tier-1/2 pure-Python deps that happen to ship as
# sourceless bytecode. `**/*.pyc` can't re-include __pycache__/ (its
# parent dir stays excluded by the __pycache__/ rule above), so this
# only tracks the real sourceless modules. New SPM targets reference
# these (see Pandas/Openpyxl/Httpx/Pypdf/Fpdf in Package.swift).
!app_packages/site-packages/pytz/**/*.pyc
!app_packages/site-packages/et_xmlfile/**/*.pyc
!app_packages/site-packages/openpyxl/**/*.pyc
!app_packages/site-packages/httpx/**/*.pyc
!app_packages/site-packages/httpcore/**/*.pyc
!app_packages/site-packages/sniffio/**/*.pyc
!app_packages/site-packages/anyio/**/*.pyc
!app_packages/site-packages/pypdf/**/*.pyc
!app_packages/site-packages/fpdf/**/*.pyc
# Utility + geospatial tier deps that ship as sourceless bytecode.
!app_packages/site-packages/tabulate/**/*.pyc
!app_packages/site-packages/jwt/**/*.pyc
!app_packages/site-packages/pendulum/**/*.pyc
!app_packages/site-packages/more_itertools/**/*.pyc
!app_packages/site-packages/sortedcontainers/**/*.pyc
!app_packages/site-packages/humanize/**/*.pyc
!app_packages/site-packages/typer/**/*.pyc
!app_packages/site-packages/lark/**/*.pyc
!app_packages/site-packages/textual/**/*.pyc
!app_packages/site-packages/xlsxwriter/**/*.pyc
!app_packages/site-packages/shellingham/**/*.pyc
!app_packages/site-packages/platformdirs/**/*.pyc
# Runtime libs (ML / git / utils) that ship as sourceless bytecode.
!app_packages/site-packages/defusedxml/**/*.pyc
!app_packages/site-packages/colorama/**/*.pyc
!app_packages/site-packages/cattrs/**/*.pyc

