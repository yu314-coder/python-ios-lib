# torch_ios: pull torch/csrc/profiler/combined_traceback.cpp into
# libtorch_python for mobile builds. Under BUILD_LITE_INTERPRETER=1 it is
# excluded from libtorch_cpu, but torch/csrc/profiler/python/init.cpp still
# references CapturedTraceback::gather/symbolize/traversePython at dlopen
# time. Also drags in two helpers (torch::jit::currentCallstack,
# torch::unwind::unwind/symbolize/stats) whose real implementations live
# in lite-excluded files — provided via torch_ios_stubs/.
#
# Apply against the pytorch checkout root.

diff --git a/torch/CMakeLists.txt b/torch/CMakeLists.txt
--- a/torch/CMakeLists.txt
+++ b/torch/CMakeLists.txt
@@ -50,6 +50,18 @@ if(INTERN_DISABLE_ONNX)
     list(FILTER TORCH_PYTHON_SRCS EXCLUDE REGEX
         "csrc/jit/passes/onnx|csrc/jit/serialization/onnx\\.cpp")
 endif()
+
+# torch_ios: BUILD_LITE_INTERPRETER=1 excludes combined_traceback.cpp from
+# libtorch_cpu, but torch/csrc/profiler/python/init.cpp (which IS compiled
+# into libtorch_python here) still calls CapturedTraceback::gather etc.,
+# producing undefined-symbol errors at dlopen time. Compile the C++ side
+# into libtorch_python directly, plus a stub file for two helpers
+# (torch::jit::currentCallstack, torch::unwind::unwind) whose real
+# implementations sit in files we deliberately don't compile for mobile.
+if(INTERN_BUILD_MOBILE AND BUILD_LITE_INTERPRETER)
+    list(APPEND TORCH_PYTHON_SRCS
+        "${TORCH_SRC_DIR}/csrc/profiler/combined_traceback.cpp"
+        "${TORCH_ROOT}/torch_ios_stubs/torch_ios_profiler_stubs.cpp")
+    # torch_ios: under lite mode, lazy/core/config.cpp + shape.cpp are not
+    # in libtorch_cpu either, so we need the manual flag definitions the
+    # torch_ios patch adds to lazy/python/init.cpp. In full mode they are
+    # already defined and re-defining would give duplicate-symbol errors.
+    set_source_files_properties(
+        "${TORCH_SRC_DIR}/csrc/lazy/python/init.cpp"
+        PROPERTIES COMPILE_DEFINITIONS TORCH_IOS_DEFINE_LAZY_FLAGS)
+endif()

 # NB: This has to match the condition under which the JIT test directory
 #     is included (at the time of writing that's in caffe2/CMakeLists.txt).
