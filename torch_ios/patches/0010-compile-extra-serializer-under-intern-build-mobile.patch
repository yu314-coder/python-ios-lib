# torch_ios: compile the `libtorch_extra_sources` serializer files
# (export_module.cpp, flatbuffer_serializer.cpp, module_save.cpp, byte_order.cpp,
# backport*.cpp, export_bytecode.cpp) under iOS full mode.
#
# Upstream gates these behind `NOT INTERN_BUILD_MOBILE AND NOT BUILD_LITE_INTERPRETER`.
# We now build with INTERN_BUILD_MOBILE=ON + BUILD_LITE_INTERPRETER=OFF (full
# "import torch" on iOS), so the Python side calls ScriptModuleSerializer::writeFiles,
# Module::save, _save_for_mobile, etc. at bind time — they must be defined.
#
# Three files stay excluded:
#   - api/src/jit.cpp                          needs missing torch/jit.h C++ API header
#   - jit/codegen/fuser/cpu/fused_kernel.cpp   calls system(3), iOS-banned
#   - jit/serialization/onnx.cpp + export.cpp  need onnx_pb.h which
#                                              INTERN_DISABLE_ONNX skips generating

diff --git a/caffe2/CMakeLists.txt b/caffe2/CMakeLists.txt
--- a/caffe2/CMakeLists.txt
+++ b/caffe2/CMakeLists.txt
@@ -582,21 +582,37 @@
   endif()
 endif()

-if(NOT INTERN_BUILD_MOBILE AND NOT BUILD_LITE_INTERPRETER)
+# torch_ios: was `NOT INTERN_BUILD_MOBILE AND NOT BUILD_LITE_INTERPRETER` —
+# for a full "import torch" build on iOS we still need the serializer /
+# export_module sources because script_init.cpp (in torch_python) calls
+# ScriptModuleSerializer::writeFiles, Module::save, etc. at bind time.
+# Three files stay excluded on iOS:
+#   - api/src/jit.cpp              needs missing torch/jit.h C++ API header
+#   - jit/codegen/fuser/cpu/fused_kernel.cpp   calls system(3) (iOS-banned)
+#   - jit/serialization/onnx.cpp + export.cpp  need onnx_pb.h which
+#     INTERN_DISABLE_ONNX skips generating
+if(NOT BUILD_LITE_INTERPRETER)
   list(APPEND TORCH_SRCS
-    ${TORCH_SRC_DIR}/csrc/api/src/jit.cpp
     ${TORCH_SRC_DIR}/csrc/jit/mobile/compatibility/backport.cpp
     ${TORCH_SRC_DIR}/csrc/jit/mobile/compatibility/backport_manager.cpp
-    ${TORCH_SRC_DIR}/csrc/jit/serialization/onnx.cpp
-    ${TORCH_SRC_DIR}/csrc/jit/serialization/export.cpp
     ${TORCH_SRC_DIR}/csrc/jit/serialization/export_bytecode.cpp
     ${TORCH_SRC_DIR}/csrc/jit/serialization/export_module.cpp
     ${TORCH_SRC_DIR}/csrc/jit/serialization/flatbuffer_serializer.cpp
-    ${TORCH_SRC_DIR}/csrc/jit/codegen/fuser/cpu/fused_kernel.cpp
     ${TORCH_SRC_DIR}/csrc/jit/api/module_save.cpp
     ${TORCH_SRC_DIR}/csrc/utils/byte_order.cpp
   )
+  if(NOT INTERN_BUILD_MOBILE)
+    list(APPEND TORCH_SRCS
+      ${TORCH_SRC_DIR}/csrc/api/src/jit.cpp
+      ${TORCH_SRC_DIR}/csrc/jit/codegen/fuser/cpu/fused_kernel.cpp
+    )
+  endif()
+  if(NOT INTERN_DISABLE_ONNX)
+    list(APPEND TORCH_SRCS
+      ${TORCH_SRC_DIR}/csrc/jit/serialization/onnx.cpp
+      ${TORCH_SRC_DIR}/csrc/jit/serialization/export.cpp)
+  endif()

   # Disable legacy import of building without Caffe2 support
   if(BUILD_CAFFE2)
